# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/vipani

# JWT
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# App
APP_NAME=Vipani
ENVIRONMENT=development

# Firebase Admin (optional — for /auth/firebase/*). Download service account JSON from Firebase Console.
# Set ONE of:
# FIREBASE_CREDENTIALS_PATH=/absolute/path/to/serviceAccount.json
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_JSON=
